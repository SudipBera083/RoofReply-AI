# Database Configurations
DB_NAME=roofreply_db
DB_USER=roofreply_user
DB_PASSWORD=roofreply_password
DB_HOST=localhost
DB_PORT=5432

# Redis Broker Url
REDIS_URL=redis://localhost:6379/0

# Django Settings
DJANGO_DEBUG=True
DJANGO_SECRET_KEY=django-insecure-make-sure-to-generate-a-secure-one-for-production
ALLOWED_HOSTS=localhost,127.0.0.1

# OpenAI API Integration
OPENAI_API_KEY=your_openai_api_key_here

# Twilio SMS & Call Integration
TWILIO_ACCOUNT_SID=your_twilio_account_sid_here
TWILIO_AUTH_TOKEN=your_twilio_auth_token_here
TWILIO_NUMBER=+15555555555

# Stripe Billing Integration
STRIPE_SECRET_KEY=your_stripe_secret_key_here
STRIPE_WEBHOOK_SECRET=your_stripe_webhook_secret_here
STRIPE_PRICE_ID=price_12345_roofreply_monthly
